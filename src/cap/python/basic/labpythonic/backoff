import time
import random
from functools import wraps

def retry_with_backoff(retries=3, delay=1.0, backoff=2.0, max_delay=10.0):
    """
    Decorador para reintentar una función con retroceso exponencial.
    """
    def decorator(func):
        @wraps(func)
        def wrapper(*args, **kwargs):
            current_delay = delay
            for attempt in range(1, retries + 1):
                try:
                    return func(*args, **kwargs)
                except Exception as e:
                    if attempt == retries:
                        print(f"Falló después de {retries} intentos. Lanzando excepción.")
                        raise e

                    # Calcular el backoff exponencial con un poco de jitter (aleatoriedad)
                    sleep_time = min(current_delay + random.uniform(0, 0.5), max_delay)
                    print(f"⚠️ Intento {attempt} falló ({e}). Reintentando en {sleep_time:.2f}s...")
                    time.sleep(sleep_time)
                    current_delay *= backoff
        return wrapper
    return decorator

# Ejemplo de uso:
@retry_with_backoff(retries=3, delay=1)
def conectar_api():
    if random.random() < 0.8:  # Simula un 80% de probabilidad de fallo
        raise ConnectionError("Servidor no responde")
    return "¡Conexión exitosa!"

try:
    conectar_api()
except Exception:
    pass
